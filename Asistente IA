<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CASTOR – Tu Asesor de Oposiciones</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bangers&family=Nunito:wght@400;600;700;800&display=swap');

  :root {
    --yellow: rgb(250, 250, 0);
    --yellow-dim: rgba(250,250,0,0.15);
    --yellow-glow: rgba(250,250,0,0.4);
    --red: #cc2200;
    --red-dark: #991a00;
    --dark: #0a0a0a;
    --dark2: #141414;
    --dark3: #1e1e1e;
    --text: #f0f0e0;
    --text-muted: #aaa88a;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'Nunito', sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: 
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(250,250,0,0.06) 0%, transparent 70%),
      repeating-linear-gradient(90deg, transparent 0px, transparent 39px, rgba(250,250,0,0.025) 40px);
    pointer-events: none;
    z-index: 0;
  }

  header {
    position: relative;
    z-index: 10;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a0800 50%, #0a0a0a 100%);
    border-bottom: 2px solid var(--red);
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: 0 4px 30px rgba(204,34,0,0.3), 0 0 60px rgba(250,250,0,0.05);
  }

  .castor-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 3px solid var(--yellow);
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.8));
    box-shadow: 0 0 20px var(--yellow-glow), 0 0 40px rgba(250,250,0,0.15);
    object-fit: cover;
    flex-shrink: 0;
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px var(--yellow-glow), 0 0 40px rgba(250,250,0,0.15); }
    50% { box-shadow: 0 0 30px rgba(250,250,0,0.7), 0 0 60px rgba(250,250,0,0.3); }
  }

  .header-text h1 {
    font-family: 'Bangers', cursive;
    font-size: 2.8rem;
    color: var(--yellow);
    letter-spacing: 4px;
    text-shadow: 0 0 20px rgba(250,250,0,0.5), 3px 3px 0 var(--red);
    line-height: 1;
  }

  .header-text p {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .badge {
    margin-left: auto;
    background: var(--red);
    color: var(--yellow);
    font-family: 'Bangers', cursive;
    font-size: 1rem;
    letter-spacing: 2px;
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid rgba(250,250,0,0.3);
    white-space: nowrap;
  }

  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 24px 20px;
    gap: 20px;
    position: relative;
    z-index: 1;
  }

  .topic-section {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .topic-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  .pill {
    background: var(--dark3);
    border: 1px solid rgba(250,250,0,0.2);
    color: var(--yellow);
    font-family: 'Nunito', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .pill:hover {
    background: var(--yellow-dim);
    border-color: var(--yellow);
    box-shadow: 0 0 12px rgba(250,250,0,0.2);
    transform: translateY(-1px);
  }

  .chat-box {
    background: var(--dark2);
    border: 1px solid rgba(250,250,0,0.12);
    border-radius: 16px;
    flex: 1;
    min-height: 340px;
    max-height: 460px;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    scroll-behavior: smooth;
  }

  .chat-box::-webkit-scrollbar { width: 6px; }
  .chat-box::-webkit-scrollbar-track { background: transparent; }
  .chat-box::-webkit-scrollbar-thumb { background: rgba(250,250,0,0.2); border-radius: 3px; }

  .welcome { display: flex; gap: 14px; align-items: flex-start; }

  .welcome-avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 2px solid var(--yellow);
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 0 12px var(--yellow-glow);
  }

  .welcome-bubble {
    background: linear-gradient(135deg, #1a1000, #1a0800);
    border: 1px solid rgba(250,250,0,0.2);
    border-radius: 4px 16px 16px 16px;
    padding: 14px 18px;
    flex: 1;
  }

  .welcome-bubble strong {
    display: block;
    color: var(--yellow);
    font-size: 0.95rem;
    margin-bottom: 6px;
    font-weight: 800;
  }

  .welcome-bubble p { font-size: 0.88rem; line-height: 1.6; color: var(--text); }

  .welcome-bubble .source-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 10px;
    font-size: 0.75rem;
    color: var(--yellow);
    text-decoration: none;
    font-weight: 700;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .welcome-bubble .source-link:hover { opacity: 1; }

  .msg-user { display: flex; justify-content: flex-end; gap: 10px; align-items: flex-end; }

  .msg-user-bubble {
    background: var(--red);
    color: #fff;
    border-radius: 16px 16px 4px 16px;
    padding: 12px 16px;
    max-width: 80%;
    font-size: 0.9rem;
    line-height: 1.5;
    box-shadow: 0 4px 15px rgba(204,34,0,0.3);
  }

  .msg-ai { display: flex; gap: 12px; align-items: flex-start; }

  .msg-ai-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 2px solid var(--yellow);
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 0 8px var(--yellow-glow);
  }

  .msg-ai-bubble {
    background: var(--dark3);
    border: 1px solid rgba(250,250,0,0.15);
    border-radius: 4px 16px 16px 16px;
    padding: 14px 18px;
    max-width: 85%;
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--text);
  }

  .msg-ai-bubble strong { color: var(--yellow); }
  .msg-ai-bubble em { color: rgba(250,250,0,0.7); font-style: normal; }

  .typing { display: flex; align-items: center; gap: 5px; padding: 4px 0; }
  .typing span {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--yellow);
    animation: bounce 1.2s infinite;
    opacity: 0.7;
  }
  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.7; }
    40% { transform: translateY(-8px); opacity: 1; }
  }

  .input-area {
    background: var(--dark2);
    border: 1.5px solid rgba(250,250,0,0.2);
    border-radius: 16px;
    padding: 14px 16px;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .input-area:focus-within {
    border-color: var(--yellow);
    box-shadow: 0 0 20px rgba(250,250,0,0.15);
  }

  .input-mode-tabs { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }

  .mode-tab {
    background: transparent;
    border: 1px solid rgba(250,250,0,0.2);
    color: var(--text-muted);
    font-family: 'Nunito', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .mode-tab.active { background: var(--yellow); color: #0a0a0a; border-color: var(--yellow); }

  .input-row { display: flex; gap: 10px; align-items: flex-end; }

  textarea {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'Nunito', sans-serif;
    font-size: 0.92rem;
    resize: none;
    min-height: 48px;
    max-height: 140px;
    line-height: 1.5;
  }
  textarea::placeholder { color: var(--text-muted); }

  .send-btn {
    background: var(--yellow);
    color: #0a0a0a;
    border: none;
    width: 46px; height: 46px;
    border-radius: 12px;
    cursor: pointer;
    font-size: 1.3rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
    box-shadow: 0 4px 15px rgba(250,250,0,0.25);
  }
  .send-btn:hover { transform: scale(1.08); box-shadow: 0 6px 20px rgba(250,250,0,0.4); }
  .send-btn:active { transform: scale(0.96); }
  .send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  footer {
    text-align: center;
    padding: 12px;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.25);
    position: relative;
    z-index: 1;
  }

  .error-bubble {
    background: rgba(204,34,0,0.15);
    border: 1px solid var(--red);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 0.83rem;
    color: #ff8870;
    text-align: center;
  }

  @media (max-width: 600px) {
    .header-text h1 { font-size: 2rem; }
    .badge { display: none; }
    .castor-avatar { width: 60px; height: 60px; }
  }
</style>
</head>
<body>

<header>
  <img class="castor-avatar" src="castor.jpg" alt="CASTOR">
  <div class="header-text">
    <h1>⛏ CASTOR</h1>
    <p>Tu asesor inteligente de oposiciones</p>
  </div>
  <div class="badge">🦫 ENFOCADOS</div>
</header>

<main>

  <div class="topic-section">
    <span class="topic-label">Acceso rápido:</span>
    <button class="pill" onclick="insertQuestion('¿Puedes explicarme el tema de la Constitución Española?')">📜 Constitución</button>
    <button class="pill" onclick="insertQuestion('¿Cómo funciona la Administración Pública española?')">🏛️ Admin. Pública</button>
    <button class="pill" onclick="insertQuestion('Explícame los derechos fundamentales')">⚖️ Derechos Fund.</button>
    <button class="pill" onclick="insertQuestion('¿Qué es el procedimiento administrativo?')">📋 Proc. Admin.</button>
    <button class="pill" onclick="insertQuestion('Corrígeme este supuesto práctico:')">✍️ Supuesto</button>
  </div>

  <div class="chat-box" id="chatBox">
    <div class="welcome">
      <img class="welcome-avatar" src="castor.jpg" alt="CASTOR">
      <div class="welcome-bubble">
        <strong>¡Hola, opositor! Soy CASTOR 🦫⛏</strong>
        <p>Estoy aquí para ayudarte a preparar tu oposición. Puedes preguntarme sobre el <strong>temario</strong>, pedirme que resuelva <strong>preguntas tipo test</strong> o que analice un <strong>supuesto práctico</strong>.</p>
        <p style="margin-top:8px">¿Cuál es tu duda de hoy?</p>
        <a class="source-link" href="https://notebooklm.google.com/notebook/7445ab4f-0be0-4680-8048-ff5dc6d30d93" target="_blank">
          📚 Consultar material base (NotebookLM)
        </a>
      </div>
    </div>
  </div>

  <div class="input-area">
    <div class="input-mode-tabs">
      <button class="mode-tab active" onclick="setMode(this,'temario')">📚 Temario</button>
      <button class="mode-tab" onclick="setMode(this,'test')">✅ Pregunta test</button>
      <button class="mode-tab" onclick="setMode(this,'supuesto')">📝 Supuesto</button>
      <button class="mode-tab" onclick="setMode(this,'esquema')">🗂️ Esquema</button>
    </div>
    <div class="input-row">
      <textarea id="questionInput"
        placeholder="Escribe tu duda aquí…"
        rows="2"
        onkeydown="handleKey(event)"
        oninput="autoResize(this)"></textarea>
      <button class="send-btn" id="sendBtn" onclick="sendMessage()">⬆</button>
    </div>
  </div>

</main>

<footer>CASTOR · Asistente de Oposiciones · Powered by IA · Material de referencia: NotebookLM</footer>

<script>
  let currentMode = 'temario';
  let isLoading = false;
  const AVATAR_SRC = document.querySelector('.castor-avatar').src;

  function setMode(btn, mode) {
    document.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    currentMode = mode;
    const placeholders = {
      temario: 'Explícame el tema de… / ¿Qué es…? / Diferencias entre…',
      test: 'Escribe la pregunta tipo test y opciones A, B, C, D…',
      supuesto: 'Pega aquí el supuesto práctico para que lo analice y resuelva…',
      esquema: 'Dime el tema y te haré un esquema para estudiar…'
    };
    document.getElementById('questionInput').placeholder = placeholders[mode];
  }

  function insertQuestion(text) {
    const ta = document.getElementById('questionInput');
    ta.value = text;
    ta.focus();
    autoResize(ta);
  }

  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 140) + 'px';
  }

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  }

  function getModePrefix() {
    const prefixes = {
      temario: 'El opositor pregunta sobre el temario: ',
      test: 'El opositor quiere que analices esta pregunta tipo test y expliques la respuesta correcta: ',
      supuesto: 'El opositor presenta el siguiente supuesto práctico. Analízalo, identifica los artículos aplicables y resuelve el caso: ',
      esquema: 'El opositor quiere un esquema de estudio completo sobre: '
    };
    return prefixes[currentMode] || '';
  }

  function addUserMessage(text) {
    const box = document.getElementById('chatBox');
    const div = document.createElement('div');
    div.className = 'msg-user';
    div.innerHTML = `<div class="msg-user-bubble">${text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>`;
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
  }

  function addTypingIndicator() {
    const box = document.getElementById('chatBox');
    const div = document.createElement('div');
    div.className = 'msg-ai';
    div.id = 'typingIndicator';
    div.innerHTML = `<img class="msg-ai-avatar" src="${AVATAR_SRC}"><div class="msg-ai-bubble"><div class="typing"><span></span><span></span><span></span></div></div>`;
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
  }

  function removeTypingIndicator() {
    const el = document.getElementById('typingIndicator');
    if (el) el.remove();
  }

  function addAIMessage(text) {
    const box = document.getElementById('chatBox');
    const div = document.createElement('div');
    div.className = 'msg-ai';
    const formatted = text
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/^### (.+)$/gm, '<strong style="color:var(--yellow);display:block;margin-top:10px">$1</strong>')
      .replace(/^## (.+)$/gm, '<strong style="color:var(--yellow);font-size:1.05rem;display:block;margin-top:12px">$1</strong>')
      .replace(/^- (.+)$/gm, '&bull; $1<br>')
      .replace(/\n\n/g, '<br><br>')
      .replace(/\n/g, '<br>');
    div.innerHTML = `<img class="msg-ai-avatar" src="${AVATAR_SRC}"><div class="msg-ai-bubble">${formatted}</div>`;
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
  }

  function addErrorMessage(text) {
    const box = document.getElementById('chatBox');
    const div = document.createElement('div');
    div.className = 'error-bubble';
    div.textContent = text;
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
  }

  async function sendMessage() {
    if (isLoading) return;
    const ta = document.getElementById('questionInput');
    const question = ta.value.trim();
    if (!question) return;

    isLoading = true;
    document.getElementById('sendBtn').disabled = true;
    ta.value = '';
    ta.style.height = 'auto';

    addUserMessage(question);
    addTypingIndicator();

    const systemPrompt = `Eres CASTOR, un asistente experto en preparación de oposiciones españolas. Tienes un profundo conocimiento del temario de oposiciones, incluyendo:
- Constitución Española de 1978
- Organización del Estado: Gobierno, Cortes Generales, Tribunal Constitucional
- Administración General del Estado y Administraciones Públicas
- Derechos y libertades fundamentales
- Procedimiento administrativo (Ley 39/2015 y Ley 40/2015)
- Función pública y empleo público (TREBEP)
- Derecho administrativo general
- Régimen local

Tu material de referencia principal es: https://notebooklm.google.com/notebook/7445ab4f-0be0-4680-8048-ff5dc6d30d93

Responde de forma clara, estructurada y pedagógica, con referencias legales exactas (artículos y leyes). Para supuestos prácticos: identificación del problema → normativa aplicable → resolución → conclusión. Responde siempre en español.`;

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system: systemPrompt,
          messages: [{ role: 'user', content: getModePrefix() + question }]
        })
      });

      const data = await response.json();
      removeTypingIndicator();

      if (data.content && data.content[0]) {
        addAIMessage(data.content[0].text);
      } else {
        addErrorMessage('⚠️ Error al obtener respuesta. Inténtalo de nuevo.');
      }
    } catch (err) {
      removeTypingIndicator();
      addErrorMessage('⚠️ Error de conexión. Verifica tu conexión e inténtalo de nuevo.');
    }

    isLoading = false;
    document.getElementById('sendBtn').disabled = false;
    ta.focus();
  }
</script>
</body>
</html>
